# Runtime state created by the launchers
/drive/
/native/.dosbox.generated.conf
# macOS: the .app the launcher extracts from the bundled (tracked) dmg
/native/bin/macos/*.app/

# Build / packaging output
/dist/
WordStar-4/
node_modules/
*.log

# js-dos browser autosave + stray screenshots
# (the intentional social-share image is a .jpg, so it isn't caught by this)
/web/wordstar.jsdos.changes
/web/*.png
