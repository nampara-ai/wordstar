# DOSBox config template for the desktop launchers.
# The launcher copies this file and fills in the drive placeholder with the
# absolute path of your WordStar folder (the program plus your documents),
# then boots straight into WordStar.
#
# Kept intentionally minimal so it works unchanged on both DOSBox Staging
# and classic DOSBox. Press Alt-Enter at any time for fullscreen.

[sdl]
fullscreen=false

[cpu]
# Pin a fixed, modest CPU speed instead of "auto". With cycles=auto, DOSBox
# Staging can ramp the emulated CPU up under sustained key-repeat (e.g. holding
# an arrow key to scroll), which outpaces WordStar's optimized screen redraw and
# garbles the display until the next full repaint. A fixed value keeps redraws
# coherent. 3000 is already ~10x a 1987 PC, so it stays instant for a text editor.
cycles=3000

[autoexec]
@echo off
mount c "__DRIVE__"
c:
cls
ws
