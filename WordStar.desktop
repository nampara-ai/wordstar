[Desktop Entry]
Type=Application
Version=1.0
Name=WordStar 4.0
GenericName=Word Processor
Comment=Write in the real 1987 WordStar on your modern computer
# Locate this .desktop file's own folder (handles plain paths and file:// URIs),
# then run the Linux launcher next to it. %k is passed as a separate argument
# (it becomes $0 of the sh -c script) because the Desktop Entry spec forbids
# field codes inside a quoted string — expansion there is undefined.
Exec=sh -c 'p="$0"; p="${p#file://}"; cd "$(dirname "$p")" && exec ./wordstar.sh' %k
Path=
Terminal=true
Icon=accessories-text-editor
Categories=Office;WordProcessor;TextEditor;
Keywords=wordstar;word;processor;writing;dos;
